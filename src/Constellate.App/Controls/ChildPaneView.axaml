<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Constellate.App"
             xmlns:panes="clr-namespace:Constellate.App.Controls.Panes"
             x:Class="Constellate.App.Controls.ChildPaneView"
             x:DataType="app:ChildPaneDescriptor">
  <UserControl.Resources>
    <app:BooleanNotConverter x:Key="BooleanNotConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="panes|PaneChrome#ChildChrome.dragHover Border#PART_PaneChromeOutline">
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildLabelArea:pointerover">
      <Setter Property="Background" Value="#2A435A"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildEmptyHeaderArea:pointerover">
      <Setter Property="Background" Value="#223240"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </UserControl.Styles>

  <panes:PaneChrome x:Name="ChildChrome"
                    IsBodyVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}"
                    PointerWheelChanged="OnPaneChromePointerWheelChanged">
    <panes:PaneChrome.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Move to Left"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToLeftHostCommand}"
                  CommandParameter="{Binding Id}" />
        <Separator />
        <MenuItem Header="Destroy This Pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Top"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToTopHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Right"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToRightHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Bottom"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToBottomHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Floating"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToFloatingHostCommand}"
                  CommandParameter="{Binding Id}" />
      </ContextMenu>
    </panes:PaneChrome.ContextMenu>

    <panes:PaneChrome.LabelContent>
      <Border x:Name="ChildLabelArea"
              Background="#213244"
              BorderBrush="#314B62"
              BorderThickness="1"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane."
              Padding="4,0"
              PointerPressed="Header_OnPointerPressed"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename Pane…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RenamePaneCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </Border.ContextMenu>
        <TextBlock Text="{Binding Title}"
                   FontSize="12"
                   Foreground="#E5EDF7"
                   VerticalAlignment="Center"/>
      </Border>
    </panes:PaneChrome.LabelContent>

    <panes:PaneChrome.EmptyHeaderContent>
      <Border x:Name="ChildEmptyHeaderArea"
              Background="#1A2633"
              Opacity="1"
              CornerRadius="3"
              BorderBrush="#24384A"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane. Double-click to minimize it."
              BorderThickness="1"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited"
              DoubleTapped="EmptyHeader_OnDoubleTapped"
              PointerPressed="Header_OnPointerPressed">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Add CommandBar Button…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).AddCommandBarButtonCommand}"
                      CommandParameter="{Binding Id}"/>
          </ContextMenu>
        </Border.ContextMenu>
      </Border>
    </panes:PaneChrome.EmptyHeaderContent>

    <panes:PaneChrome.CommandBarContent>
      <Grid>
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="–"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Minimize child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MinimizeChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="□"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Restore child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RestoreChildPaneFromTaskbarCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>
      </Grid>
    </panes:PaneChrome.CommandBarContent>

    <panes:PaneChrome.BodyContent>
      <Border x:Name="ChildBodyDragArea"
              Background="#101722"
              CornerRadius="2"
              Padding="6"
              ToolTip.Tip="Drag empty child-body space to move or float this child pane."
              PointerPressed="Body_OnPointerPressed"
              Cursor="Hand"
              PointerEntered="Body_OnPointerEntered"
              PointerExited="Body_OnPointerExited">
        <StackPanel Spacing="8">
          <TextBlock x:Name="EmptyChildPaneBodyText"
                     Text="(empty child pane)"
                     Foreground="#9BA8B7"
                     FontSize="11"/>
          <Border x:Name="BoundResourceContextReadout"
                  IsVisible="False"
                  Background="#162535"
                  BorderBrush="#3A6E8E"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="2">
              <TextBlock Text="Bound Resource Context"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock x:Name="BoundResourceContextTitleText"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <TextBlock x:Name="BoundResourceContextSubtitleText"
                         Foreground="#D4E5F3"
                         FontSize="10"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </panes:PaneChrome.BodyContent>
  </panes:PaneChrome>
</UserControl>
