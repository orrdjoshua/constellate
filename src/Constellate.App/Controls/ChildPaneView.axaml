<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Constellate.App"
             xmlns:panes="clr-namespace:Constellate.App.Controls.Panes"
             x:Class="Constellate.App.Controls.ChildPaneView"
             x:DataType="app:ChildPaneDescriptor">
  <UserControl.Resources>
    <app:BooleanNotConverter x:Key="BooleanNotConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="panes|PaneChrome#ChildChrome.dragHover Border#PART_PaneChromeOutline">
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildLabelArea:pointerover">
      <Setter Property="Background" Value="#2A435A"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildEmptyHeaderArea:pointerover">
      <Setter Property="Background" Value="#223240"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </UserControl.Styles>

  <panes:PaneChrome x:Name="ChildChrome"
                    IsBodyVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}"
                    PointerWheelChanged="OnPaneChromePointerWheelChanged">
    <panes:PaneChrome.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Move to Left"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToLeftHostCommand}"
                  CommandParameter="{Binding Id}" />
        <Separator />
        <MenuItem Header="Destroy This Pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Top"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToTopHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Right"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToRightHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Bottom"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToBottomHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Floating"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToFloatingHostCommand}"
                  CommandParameter="{Binding Id}" />
      </ContextMenu>
    </panes:PaneChrome.ContextMenu>

    <panes:PaneChrome.LabelContent>
      <Border x:Name="ChildLabelArea"
              Background="{Binding PaneHeaderBackgroundBrush}"
              BorderBrush="{Binding PaneHeaderBorderBrush}"
              BorderThickness="1"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane."
              Padding="4,2"
              PointerPressed="Header_OnPointerPressed"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename Pane…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RenamePaneCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Spacing="2">
          <TextBlock Text="{Binding Title}"
                     FontSize="12"
                     Foreground="#E5EDF7"
                     VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal"
                      Spacing="4"
                      IsVisible="{Binding HasPaneSourcePresentation}">
            <Border Background="#25435D"
                    BorderBrush="#3A6E8E"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="4,1"
                    IsVisible="{Binding HasPaneSourcePrimaryBadge}">
              <TextBlock Text="{Binding PaneSourcePrimaryBadge}"
                         Foreground="#D8F0FF"
                         FontSize="9"
                         FontWeight="SemiBold"/>
            </Border>
            <Border Background="#3A2A14"
                    BorderBrush="#8C6933"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="4,1"
                    IsVisible="{Binding HasPaneSourceStatusBadge}">
              <TextBlock Text="{Binding PaneSourceStatusBadge}"
                         Foreground="#FFE5B8"
                         FontSize="9"
                         FontWeight="SemiBold"/>
            </Border>
            <TextBlock Text="{Binding PaneSourceLabel}"
                       Foreground="#AFC4D8"
                       FontSize="10"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </panes:PaneChrome.LabelContent>

    <panes:PaneChrome.EmptyHeaderContent>
      <Border x:Name="ChildEmptyHeaderArea"
              Background="{Binding PaneEmptyHeaderBackgroundBrush}"
              Opacity="1"
              CornerRadius="3"
              BorderBrush="{Binding PaneEmptyHeaderBorderBrush}"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane. Double-click to minimize it."
              BorderThickness="1"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited"
              DoubleTapped="EmptyHeader_OnDoubleTapped"
              PointerPressed="Header_OnPointerPressed">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Add CommandBar Button…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).AddCommandBarButtonCommand}"
                      CommandParameter="{Binding Id}"/>
          </ContextMenu>
        </Border.ContextMenu>
      </Border>
    </panes:PaneChrome.EmptyHeaderContent>

    <panes:PaneChrome.CommandBarContent>
      <Grid>
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="–"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Minimize child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MinimizeChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="□"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Restore child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RestoreChildPaneFromTaskbarCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>
      </Grid>
    </panes:PaneChrome.CommandBarContent>

    <panes:PaneChrome.BodyContent>
      <Border x:Name="ChildBodyDragArea"
              Background="#101722"
              CornerRadius="2"
              Padding="6"
              ToolTip.Tip="Drag empty child-body space to move or float this child pane."
              PointerPressed="Body_OnPointerPressed"
              Cursor="Hand"
              PointerEntered="Body_OnPointerEntered"
              PointerExited="Body_OnPointerExited">
        <StackPanel Spacing="8">
          <TextBlock x:Name="EmptyChildPaneBodyText"
                     Text="(empty child pane)"
                     Foreground="#9BA8B7"
                     FontSize="11"/>
          <Border Background="#14202C"
                  BorderBrush="#294056"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8"
                  IsVisible="{Binding HasPaneSourcePresentation}">
            <StackPanel Spacing="3">
              <TextBlock Text="Pane Source"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="{Binding PaneSourceLabel}"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal"
                          Spacing="4">
                <Border Background="#25435D"
                        BorderBrush="#3A6E8E"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,1"
                        IsVisible="{Binding HasPaneSourcePrimaryBadge}">
                  <TextBlock Text="{Binding PaneSourcePrimaryBadge}"
                             Foreground="#D8F0FF"
                             FontSize="9"
                             FontWeight="SemiBold"/>
                </Border>
                <Border Background="#3A2A14"
                        BorderBrush="#8C6933"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,1"
                        IsVisible="{Binding HasPaneSourceStatusBadge}">
                  <TextBlock Text="{Binding PaneSourceStatusBadge}"
                             Foreground="#FFE5B8"
                             FontSize="9"
                             FontWeight="SemiBold"/>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>
          <Border Background="#13202C"
                  BorderBrush="#2F4A5F"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Pane Definition"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="Load an existing pane definition or reset this child pane into a new local pane."
                         Foreground="#C5D5E4"
                         FontSize="11"
                         TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <ComboBox x:Name="PaneDefinitionPicker"
                          Width="220"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SeededPaneDefinitions}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayLabel}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Load Existing Definition"
                        Click="OnLoadExistingPaneClick" />
              </StackPanel>
              <Button Content="Create New Pane"
                      HorizontalAlignment="Left"
                      Click="OnCreateNewPaneClick" />
            </StackPanel>
          </Border>
          <Border Background="#13202C"
                  BorderBrush="#4A6378"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Local Description"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="Apply a pane-instance description override without mutating any reusable definition."
                         Foreground="#C5D5E4"
                         FontSize="11"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneDescriptionSummary}"
                         Foreground="#D5E4F1"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <StackPanel Spacing="6">
                <TextBox x:Name="LocalDescriptionTextBox"
                         Width="320"
                         Height="72"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         PlaceholderText="Pane description" />
                <WrapPanel Orientation="Horizontal"
                           ItemHeight="28"
                           ItemWidth="130">
                  <Button Content="Apply Description"
                          Click="OnApplyLocalDescriptionOverrideClick" />
                  <Button Content="Reset Description"
                          Click="OnResetLocalDescriptionOverrideClick"
                          IsVisible="{Binding CanResetLocalDescriptionOverride}" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
          <Border Background="#13202C"
                  BorderBrush="#4A6378"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Local Title Override"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="Apply a pane-instance title override without mutating any reusable definition."
                         Foreground="#C5D5E4"
                         FontSize="11"
                         TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <TextBox x:Name="LocalTitleOverrideTextBox"
                         Width="220"
                         PlaceholderText="Pane title"
                         Text="{Binding Title}" />
                <Button Content="Apply Title"
                        Click="OnApplyLocalTitleOverrideClick" />
                <Button Content="Reset Title"
                        Click="OnResetLocalTitleOverrideClick"
                        IsVisible="{Binding CanResetLocalTitleOverride}" />
              </StackPanel>
            </StackPanel>
          </Border>
          <Border Background="#13202C"
                  BorderBrush="#4A6378"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Local Appearance"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="Apply a child-pane-local appearance variant without mutating any reusable definition."
                         Foreground="#C5D5E4"
                         FontSize="11"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneAppearanceSummary}"
                         Foreground="#D5E4F1"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <WrapPanel Orientation="Horizontal"
                         ItemHeight="28"
                         ItemWidth="110">
                <Button Content="Default"
                        Tag="default"
                        Click="OnApplyLocalAppearanceVariantClick" />
                <Button Content="Cool"
                        Tag="cool"
                        Click="OnApplyLocalAppearanceVariantClick" />
                <Button Content="Warm"
                        Tag="warm"
                        Click="OnApplyLocalAppearanceVariantClick" />
                <Button Content="Reset Appearance"
                        Click="OnResetLocalAppearanceVariantClick"
                        IsVisible="{Binding CanResetLocalAppearanceOverride}" />
              </WrapPanel>
            </StackPanel>
          </Border>
          <Border Background="#13202C"
                  BorderBrush="#4A6378"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="6">
              <TextBlock Text="Authoring Actions"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock Text="Save this pane as instance-local state, promote it into a reusable definition, detach it into local state, or revert it back to its current definition."
                         Foreground="#C5D5E4"
                         FontSize="11"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneWorkingCopyStatusSummary}"
                         Foreground="#AFC4D8"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneWorkingCopySourceSummary}"
                         Foreground="#9FC9E7"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneWorkingCopyDefinitionSyncSummary}"
                         Foreground="#9FC9E7"
                         FontSize="10"
                         TextWrapping="Wrap"
                         IsVisible="{Binding HasPaneWorkingCopyDefinitionSyncSummary}"/>
              <TextBlock Text="{Binding PaneWorkingCopyLocalStateSummary}"
                         Foreground="#9FC9E7"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneLocalOverrideSummary}"
                         Foreground="#D5E4F1"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding PaneLifecycleActionSummary}"
                         Foreground="#D5E4F1"
                         FontSize="10"
                         TextWrapping="Wrap"/>
              <ItemsControl ItemsSource="{Binding PaneWorkingCopyActiveOverrideAxisLabels}"
                            IsVisible="{Binding HasPaneWorkingCopyOverrideAxes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#213244"
                            BorderBrush="#48627B"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="0,0,6,6">
                      <TextBlock Text="{Binding .}"
                                 Foreground="#DDEBFA"
                                 FontSize="9"
                                 FontWeight="SemiBold"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <WrapPanel Orientation="Horizontal"
                         ItemHeight="28"
                         ItemWidth="150">
                <Button Content="Save Instance Only"
                        Click="OnSaveInstanceOnlyClick"
                        IsVisible="{Binding CanSaveInstanceOnly}" />
                <Button Content="Save As New Definition"
                        Click="OnSaveAsNewDefinitionClick"
                        IsVisible="{Binding CanSaveAsNewDefinition}" />
                <Button Content="Detach from Definition"
                        Click="OnDetachFromDefinitionClick"
                        IsVisible="{Binding CanDetachFromDefinition}" />
                <Button Content="Revert to Definition"
                        Click="OnRevertToDefinitionClick"
                        IsVisible="{Binding CanRevertToDefinition}" />
              </WrapPanel>
            </StackPanel>
          </Border>
          <Border x:Name="BoundResourceContextReadout"
                  IsVisible="False"
                  Background="#162535"
                  BorderBrush="#3A6E8E"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="2">
              <TextBlock Text="Bound Resource Surface"
                         Foreground="#A9DDF9"
                         FontSize="10"/>
              <TextBlock x:Name="BoundResourceContextTitleText"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <TextBlock x:Name="BoundResourceContextSubtitleText"
                         Foreground="#D4E5F3"
                         FontSize="10"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </panes:PaneChrome.BodyContent>
  </panes:PaneChrome>
</UserControl>
