<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Constellate.App"
             xmlns:panes="clr-namespace:Constellate.App.Controls.Panes"
             x:Class="Constellate.App.Controls.ChildPaneView"
             x:DataType="app:ChildPaneDescriptor">
  <UserControl.Resources>
    <app:BooleanNotConverter x:Key="BooleanNotConverter"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="panes|PaneChrome#ChildChrome.dragHover Border#PART_PaneChromeOutline">
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildLabelArea:pointerover">
      <Setter Property="Background" Value="#2A435A"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ChildEmptyHeaderArea:pointerover">
      <Setter Property="Background" Value="#223240"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </UserControl.Styles>

  <panes:PaneChrome x:Name="ChildChrome"
                    IsBodyVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}"
                    PointerWheelChanged="OnPaneChromePointerWheelChanged">
    <panes:PaneChrome.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Move to Left"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToLeftHostCommand}"
                  CommandParameter="{Binding Id}" />
        <Separator />
        <MenuItem Header="Destroy This Pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Top"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToTopHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Right"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToRightHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Bottom"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToBottomHostCommand}"
                  CommandParameter="{Binding Id}" />
        <MenuItem Header="Move to Floating"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToFloatingHostCommand}"
                  CommandParameter="{Binding Id}" />
      </ContextMenu>
    </panes:PaneChrome.ContextMenu>

    <panes:PaneChrome.LabelContent>
      <Border x:Name="ChildLabelArea"
              Background="{Binding PaneHeaderBackgroundBrush}"
              BorderBrush="{Binding PaneHeaderBorderBrush}"
              BorderThickness="1"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane."
              Padding="4,2"
              PointerPressed="Header_OnPointerPressed"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename Pane…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RenamePaneCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Spacing="2">
          <Grid>
            <TextBlock Text="{Binding Title}"
                       FontSize="12"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsInlineRenaming, Converter={StaticResource BooleanNotConverter}}"/>
            <TextBox x:Name="InlineRenameEditor"
                     IsVisible="{Binding IsInlineRenaming}"
                     MinWidth="180"
                     Padding="4,0"
                     Background="#162432"
                     Foreground="#E5EDF7"
                     BorderBrush="#7DD3FC"
                     BorderThickness="1"
                     PlaceholderText="Pane title"
                     KeyDown="OnInlineRenameKeyDown"
                     LostFocus="OnInlineRenameLostFocus"/>
          </Grid>
          <StackPanel Orientation="Horizontal"
                      Spacing="4"
                      IsVisible="{Binding HasPaneSourcePresentation}">
            <Border Background="#25435D"
                    BorderBrush="#3A6E8E"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="4,1"
                    IsVisible="{Binding HasPaneSourcePrimaryBadge}">
              <TextBlock Text="{Binding PaneSourcePrimaryBadge}"
                         Foreground="#D8F0FF"
                         FontSize="9"
                         FontWeight="SemiBold"/>
            </Border>
            <Border Background="#3A2A14"
                    BorderBrush="#8C6933"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="4,1"
                    IsVisible="{Binding HasPaneSourceStatusBadge}">
              <TextBlock Text="{Binding PaneSourceStatusBadge}"
                         Foreground="#FFE5B8"
                         FontSize="9"
                         FontWeight="SemiBold"/>
            </Border>
            <TextBlock Text="{Binding PaneSourceLabel}"
                       Foreground="#AFC4D8"
                       FontSize="10"
                       IsVisible="{Binding HasPaneSourceTextLabel}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </panes:PaneChrome.LabelContent>

    <panes:PaneChrome.EmptyHeaderContent>
      <Border x:Name="ChildEmptyHeaderArea"
              Background="{Binding PaneEmptyHeaderBackgroundBrush}"
              Opacity="1"
              CornerRadius="3"
              BorderBrush="{Binding PaneEmptyHeaderBorderBrush}"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this child pane. Double-click to minimize it."
              BorderThickness="1"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited"
              DoubleTapped="EmptyHeader_OnDoubleTapped"
              PointerPressed="Header_OnPointerPressed">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Add CommandBar Button…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).AddCommandBarButtonCommand}"
                      CommandParameter="{Binding Id}"/>
            <Separator />
            <MenuItem Header="Save Instance Only"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneInstanceOnlyCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanSaveInstanceOnly}" />
            <MenuItem Header="Save As New Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneAsNewDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanSaveAsNewDefinition}" />
            <MenuItem Header="Detach from Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DetachChildPaneFromDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanDetachFromDefinition}" />
            <MenuItem Header="Revert to Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RevertChildPaneToDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanRevertToDefinition}" />
            <Separator />
            <MenuItem Header="Apply Default Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneDefaultAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Apply Cool Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneCoolAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Apply Warm Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneWarmAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Reset Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ResetChildPaneAppearanceVariantCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanResetLocalAppearanceOverride}" />
          </ContextMenu>
        </Border.ContextMenu>
      </Border>
    </panes:PaneChrome.EmptyHeaderContent>

    <panes:PaneChrome.CommandBarContent>
      <Grid>
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="–"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Minimize child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MinimizeChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,2,0"
                    IsVisible="{Binding IsMinimized}">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="□"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Restore child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RestoreChildPaneFromTaskbarCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>
      </Grid>
    </panes:PaneChrome.CommandBarContent>

    <panes:PaneChrome.BodyContent>
      <Border x:Name="ChildBodyDragArea"
              Background="#101722"
              CornerRadius="2"
              Padding="6"
              ToolTip.Tip="Drag empty child-body space to move or float this child pane."
              PointerPressed="Body_OnPointerPressed"
              Cursor="Hand"
              PointerEntered="Body_OnPointerEntered"
              PointerExited="Body_OnPointerExited">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename Pane…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RenamePaneCommand}"
                      CommandParameter="{Binding Id}" />
            <Separator />
            <MenuItem Header="Save Instance Only"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneInstanceOnlyCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanSaveInstanceOnly}" />
            <MenuItem Header="Save As New Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneAsNewDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanSaveAsNewDefinition}" />
            <MenuItem Header="Detach from Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DetachChildPaneFromDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanDetachFromDefinition}" />
            <MenuItem Header="Revert to Definition"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RevertChildPaneToDefinitionCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanRevertToDefinition}" />
            <Separator />
            <MenuItem Header="Apply Default Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneDefaultAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Apply Cool Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneCoolAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Apply Warm Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneWarmAppearanceCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Reset Appearance"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ResetChildPaneAppearanceVariantCommand}"
                      CommandParameter="{Binding Id}"
                      IsVisible="{Binding CanResetLocalAppearanceOverride}" />
          </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Spacing="8">
          <TextBlock x:Name="EmptyChildPaneBodyText"
                     Text="(empty child pane)"
                     IsVisible="{Binding ShouldShowDefaultEmptyBodyText}"
                     Foreground="#9BA8B7"
                     FontSize="11"/>
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="8">
              <Border x:Name="RealizedPaneDefinitionContainer"
                      Background="#101A24"
                      BorderBrush="#355066"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8"
                      IsVisible="{Binding HasDefinitionIdentity}">
                <StackPanel Spacing="6">
                  <TextBlock Text="Realized Pane Definition"
                             Foreground="#A9DDF9"
                             FontSize="10"/>
                  <ContentControl x:Name="RealizedPaneDefinitionHost"/>
                </StackPanel>
              </Border>
              <Border Background="#162535"
                      BorderBrush="#3A6E8E"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8"
                      IsVisible="{Binding HasDirectBoundResourceContextPresentation}">
                <StackPanel Spacing="2">
                  <TextBlock Text="Bound Resource Surface"
                             Foreground="#A9DDF9"
                             FontSize="10"/>
                  <TextBlock Text="{Binding PaneBoundResourceReadoutTitle}"
                             Foreground="White"
                             FontSize="12"
                             FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding PaneBoundResourceReadoutSubtitle}"
                             Foreground="#D4E5F3"
                             FontSize="10"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Background="#13202C"
                      BorderBrush="#2F4A5F"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8">
                <Expander Header="Pane Definition"
                          IsExpanded="False">
                  <StackPanel Spacing="6"
                              Margin="0,6,0,0">
                    <TextBlock Text="{Binding PaneDefinitionChooserSourceSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneDefinitionChooserActionSummary}"
                               Foreground="#C5D5E4"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                      <ComboBox x:Name="PaneDefinitionPicker"
                                Width="220"
                                HorizontalAlignment="Left"
                                SelectedValueBinding="{Binding PaneDefinitionId}"
                                SelectedValue="{Binding DefinitionId, Mode=OneWay}"
                                ItemsSource="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SeededPaneDefinitions}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayLabel}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <Button Content="Load Existing Definition"
                              Click="OnLoadExistingPaneClick" />
                    </StackPanel>
                    <Button Content="Create New Pane"
                            HorizontalAlignment="Left"
                            Click="OnCreateNewPaneClick" />
                  </StackPanel>
                </Expander>
              </Border>
              <Border Background="#13202C"
                      BorderBrush="#4A6378"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8">
                <Expander Header="Local Appearance"
                          IsExpanded="False">
                  <StackPanel Spacing="6"
                              Margin="0,6,0,0">
                    <TextBlock Text="Apply a child-pane-local appearance variant without mutating any reusable definition."
                               Foreground="#C5D5E4"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneAppearanceCurrentValueSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneAppearanceBaselineValueSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <WrapPanel Orientation="Horizontal"
                               ItemHeight="28"
                               ItemWidth="110">
                      <Button Content="Default"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneDefaultAppearanceCommand}"
                              CommandParameter="{Binding Id}" />
                      <Button Content="Cool"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneCoolAppearanceCommand}"
                              CommandParameter="{Binding Id}" />
                      <Button Content="Warm"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ApplyChildPaneWarmAppearanceCommand}"
                              CommandParameter="{Binding Id}" />
                      <Button Content="Reset Appearance"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).ResetChildPaneAppearanceVariantCommand}"
                              CommandParameter="{Binding Id}"
                              IsVisible="{Binding CanResetLocalAppearanceOverride}" />
                    </WrapPanel>
                  </StackPanel>
                </Expander>
              </Border>
              <Border Background="#13202C"
                      BorderBrush="#4A6378"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8">
                <Expander Header="Authoring Actions"
                          IsExpanded="False">
                  <StackPanel Spacing="6"
                              Margin="0,6,0,0">
                    <TextBlock Text="Save this pane as instance-local state, promote it into a reusable definition, detach it into local state, or revert it back to its current definition."
                               Foreground="#C5D5E4"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneWorkingCopyStatusSummary}"
                               Foreground="#AFC4D8"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneWorkingCopySourceSummary}"
                               Foreground="#9FC9E7"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneWorkingCopyDefinitionSyncSummary}"
                               Foreground="#9FC9E7"
                               FontSize="10"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasPaneWorkingCopyDefinitionSyncSummary}"/>
                    <TextBlock Text="{Binding PaneAuthoredValueStatusSummary}"
                               Foreground="#B9CBDC"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneWorkingCopyLocalStateSummary}"
                               Foreground="#9FC9E7"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneCurrentAuthoredSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneBaselineAuthoredSummary}"
                               Foreground="#B9CBDC"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneLocalOverrideSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PaneLifecycleActionSummary}"
                               Foreground="#D5E4F1"
                               FontSize="10"
                               TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding PaneWorkingCopyStatusBadgeLabels}"
                                  IsVisible="{Binding HasPaneWorkingCopyStatusBadges}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#243847"
                                  BorderBrush="#53728C"
                                  BorderThickness="1"
                                  CornerRadius="3"
                                  Padding="6,2"
                                  Margin="0,0,6,6">
                            <TextBlock Text="{Binding .}"
                                       Foreground="#E4F0FB"
                                       FontSize="9"
                                       FontWeight="SemiBold"/>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding PaneWorkingCopyActiveOverrideAxisLabels}"
                                  IsVisible="{Binding HasPaneWorkingCopyOverrideAxes}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#213244"
                                  BorderBrush="#48627B"
                                  BorderThickness="1"
                                  CornerRadius="3"
                                  Padding="6,2"
                                  Margin="0,0,6,6">
                            <TextBlock Text="{Binding .}"
                                       Foreground="#DDEBFA"
                                       FontSize="9"
                                       FontWeight="SemiBold"/>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <WrapPanel Orientation="Horizontal"
                               ItemHeight="28"
                               ItemWidth="150">
                      <Button Content="Save Instance Only"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneInstanceOnlyCommand}"
                              CommandParameter="{Binding Id}"
                              IsVisible="{Binding CanSaveInstanceOnly}" />
                      <Button Content="Save As New Definition"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SaveChildPaneAsNewDefinitionCommand}"
                              CommandParameter="{Binding Id}"
                              IsVisible="{Binding CanSaveAsNewDefinition}" />
                      <Button Content="Detach from Definition"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DetachChildPaneFromDefinitionCommand}"
                              CommandParameter="{Binding Id}"
                              IsVisible="{Binding CanDetachFromDefinition}" />
                      <Button Content="Revert to Definition"
                              Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RevertChildPaneToDefinitionCommand}"
                              CommandParameter="{Binding Id}"
                              IsVisible="{Binding CanRevertToDefinition}" />
                    </WrapPanel>
                  </StackPanel>
                </Expander>
              </Border>
              <Border x:Name="BoundResourceContextReadout"
                      IsVisible="False"
                      Background="#162535"
                      BorderBrush="#3A6E8E"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="8">
                <StackPanel Spacing="2">
                  <TextBlock Text="Bound Resource Surface"
                             Foreground="#A9DDF9"
                             FontSize="10"/>
                  <TextBlock x:Name="BoundResourceContextTitleText"
                             Foreground="White"
                             FontSize="12"
                             FontWeight="SemiBold"/>
                  <TextBlock x:Name="BoundResourceContextSubtitleText"
                             Foreground="#D4E5F3"
                             FontSize="10"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </StackPanel>
      </Border>
    </panes:PaneChrome.BodyContent>
  </panes:PaneChrome>
</UserControl>
