<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Constellate.App"
             x:Class="Constellate.App.Controls.ChildPaneView"
             x:DataType="app:ChildPaneDescriptor">
  <Border Background="#151E28" CornerRadius="4">
    <Grid RowDefinitions="Auto,*">
      <!-- Header: forwards pointer events to MainWindow via control code-behind wrappers -->
      <DockPanel Grid.Row="0"
                 LastChildFill="False"
                 Background="#192531"
                 PointerPressed="Header_OnPointerPressed"
                 PointerReleased="Header_OnPointerReleased"
                 PointerMoved="Header_OnPointerMoved">
        <TextBlock Text="{Binding Title}"
                   FontSize="12"
                   Foreground="#E5EDF7"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Left"
                   Margin="6,4"/>
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Margin="4,2,6,2">
          <Button Width="20"
                  Height="20"
                  Padding="0"
                  Content="–"
                  ToolTip.Tip="Minimize child pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MinimizeChildPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>

        <DockPanel.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Move to Left"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToLeftHostCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Move to Top"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToTopHostCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Move to Right"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToRightHostCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Move to Bottom"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToBottomHostCommand}"
                      CommandParameter="{Binding Id}" />
            <MenuItem Header="Move to Floating"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MoveChildPaneToFloatingHostCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </DockPanel.ContextMenu>
      </DockPanel>

      <!-- Body placeholder -->
      <Border Grid.Row="1"
              Margin="6,4,6,8"
              Background="#101722"
              CornerRadius="2"
              Padding="6">
        <TextBlock Text="(empty child pane)" Foreground="#9BA8B7" FontSize="11"/>
      </Border>
    </Grid>
  </Border>
</UserControl>
