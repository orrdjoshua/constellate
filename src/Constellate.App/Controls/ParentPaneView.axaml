<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Constellate.App"
             xmlns:ctrl="clr-namespace:Constellate.App.Controls"
             xmlns:panes="clr-namespace:Constellate.App.Controls.Panes"
             x:Class="Constellate.App.Controls.ParentPaneView"
             x:DataType="app:ParentPaneModel">
  <UserControl.Styles>
    <Style Selector="panes|PaneChrome#ParentChrome.dragHover Border#PART_PaneChromeOutline">
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ParentLabelArea:pointerover">
      <Setter Property="Background" Value="#2A435A"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Border#ParentEmptyHeaderArea:pointerover">
      <Setter Property="Background" Value="#223240"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <app:EqualsToReturnFalseConverter x:Key="EqualsToReturnFalse" />
    <app:BooleanNotConverter x:Key="BooleanNotConverter" />
  </UserControl.Resources>

  <panes:PaneChrome x:Name="ParentChrome"
                    IsBodyVisible="{Binding HasExpandedContent}"
                    PointerWheelChanged="OnPaneChromePointerWheelChanged">
    <panes:PaneChrome.LabelContent>
      <Border x:Name="ParentLabelArea"
              Background="#213244"
              BorderBrush="#314B62"
              BorderThickness="1"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this parent pane."
              Padding="4,0"
              PointerPressed="Header_OnPointerPressed"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Rename Pane…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RenamePaneCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </Border.ContextMenu>
        <TextBlock Text="{Binding Title}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#E5EDF7"
                   VerticalAlignment="Center"/>
      </Border>
    </panes:PaneChrome.LabelContent>

    <panes:PaneChrome.EmptyHeaderContent>
      <Border x:Name="ParentEmptyHeaderArea"
              Background="#1A2633"
              Opacity="1"
              CornerRadius="3"
              BorderBrush="#24384A"
              Cursor="Hand"
              ToolTip.Tip="Drag to move this parent pane. Double-click to minimize it."
              BorderThickness="1"
              PointerEntered="Header_OnPointerEntered"
              PointerExited="Header_OnPointerExited"
              DoubleTapped="EmptyHeader_OnDoubleTapped"
              PointerPressed="Header_OnPointerPressed">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Add CommandBar Button…"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).AddCommandBarButtonCommand}"
                      CommandParameter="{Binding Id}" />
          </ContextMenu>
        </Border.ContextMenu>
      </Border>
    </panes:PaneChrome.EmptyHeaderContent>

    <panes:PaneChrome.CommandBarContent>
      <Grid>
        <!-- Full command bar for expanded panes (now scrolled by header-level ScrollViewer) -->
        <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsMinimized, Converter={StaticResource BooleanNotConverter}}">
            <Border Background="#1B2A3A"
                    Padding="4,2"
                    CornerRadius="3"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal"
                          Spacing="4"
                          VerticalAlignment="Center">
                <TextBlock Text="Splits:"
                           Foreground="#CDE3FF"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <Button Content="1"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SplitCount, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=1}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSplitTo1Command}"
                        CommandParameter="{Binding Id}" />
                <Button Content="2"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SplitCount, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=2}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSplitTo2Command}"
                        CommandParameter="{Binding Id}" />
                <Button Content="3"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SplitCount, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=3}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSplitTo3Command}"
                        CommandParameter="{Binding Id}" />
              </StackPanel>
            </Border>

            <Border Background="#1B2A3A"
                    Padding="4,2"
                    CornerRadius="3"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal"
                          Spacing="4"
                          VerticalAlignment="Center">
                <TextBlock Text="Slide:"
                           Foreground="#CDE3FF"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <Button Content="1"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SlideIndex, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=0}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSlideTo1Command}"
                        CommandParameter="{Binding Id}" />
                <Button Content="2"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SlideIndex, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=1}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSlideTo2Command}"
                        CommandParameter="{Binding Id}" />
                <Button Content="3"
                        Padding="4,0"
                        FontSize="11"
                        Foreground="#E5EDF7"
                        Background="#233142"
                        IsEnabled="{Binding SlideIndex, Converter={StaticResource EqualsToReturnFalse}, ConverterParameter=2}"
                        Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).SetParentSlideTo3Command}"
                        CommandParameter="{Binding Id}" />
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
              <Button Width="22"
                      Height="22"
                      Padding="0"
                      Content="+"
                      Foreground="#E5EDF7"
                      Background="#233142"
                      ToolTip.Tip="Add child pane"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).CreateChildPaneCommand}"
                      CommandParameter="{Binding Id}" />
              <Button Width="22"
                      Height="22"
                      Padding="0"
                      Content="–"
                      Foreground="#E5EDF7"
                      Background="#233142"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).MinimizeShellPaneCommand}"
                      CommandParameter="{Binding Id}" />
              <Button Width="22"
                      Height="22"
                      Padding="0"
                      Content="×"
                      Foreground="#E5EDF7"
                      Background="#233142"
                      ToolTip.Tip="Destroy pane"
                      Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyParentPaneCommand}"
                      CommandParameter="{Binding Id}" />
            </StackPanel>
        </StackPanel>

        <!-- Minimal command bar for minimized panes: restore + destroy only -->
        <StackPanel Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsMinimized}">
          <Button Width="22"
                  Height="22"
                  Padding="0"
                  Content="□"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Restore pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).RestoreShellPaneCommand}"
                  CommandParameter="{Binding Id}" />
          <Button Width="22"
                  Height="22"
                  Padding="0"
                  Content="×"
                  Foreground="#E5EDF7"
                  Background="#233142"
                  ToolTip.Tip="Destroy pane"
                  Command="{Binding $parent[Window].((app:MainWindowViewModel)DataContext).DestroyParentPaneCommand}"
                  CommandParameter="{Binding Id}" />
        </StackPanel>
      </Grid>
    </panes:PaneChrome.CommandBarContent>

    <panes:PaneChrome.PreBodyContent>
      <ctrl:MinimizedChildTaskbarView IsVisible="{Binding HasExpandedContent}"
                                      ZIndex="50"/>
    </panes:PaneChrome.PreBodyContent>

    <panes:PaneChrome.BodyContent>
      <Grid IsVisible="{Binding HasExpandedContent}"
            ToolTip.Tip="Drag empty parent-body space to move this parent pane."
            ZIndex="0">
        <ctrl:ParentBodyPresenter />
      </Grid>
    </panes:PaneChrome.BodyContent>
  </panes:PaneChrome>
</UserControl>
