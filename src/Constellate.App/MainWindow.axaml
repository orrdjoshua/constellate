<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        xmlns:app="clr-namespace:Constellate.App"
        xmlns:cap="clr-namespace:Constellate.Core.Capabilities;assembly=Constellate.Core"
        x:Class="Constellate.App.MainWindow"
        x:DataType="app:MainWindowViewModel"
        Width="1200" Height="760"
        Title="Constellate — Hybrid 2D/3D">
  <Window.Resources>
    <!-- Shared shell pane content template; hosted in left/top/right/bottom/floating parent panes. -->
    <DataTemplate x:Key="ShellPaneContentTemplate"
                  x:DataType="app:MainWindowViewModel">
      <Border Background="#0B1017"
              BorderBrush="#2B3A4D"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Constellate Shell"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#F4F7FB"
                       DockPanel.Dock="Left" />
            <Button Classes="SidebarActionButton"
                    Content="–"
                    Width="28"
                    Height="24"
                    HorizontalAlignment="Right"
                    Margin="6,0,0,0"
                    Command="{Binding MinimizeShellPaneCommand}"
                    ToolTip.Tip="Minimize shell pane to edge" />
          </DockPanel>

          <TextBlock Text="Viewport interaction remains primary. Right-click context surfaces in the 3D world (background, node, link, group) are the first way to access commands; the shell pane is an organized, collapsible secondary surface so tools stay compact and developer diagnostics remain available but secondary."
                     Foreground="#C7D2DE"
                     Opacity="0.95"
                     TextWrapping="Wrap" />

          <!-- Per-parent child-pane taskbar for minimized child panes -->
          <StackPanel Orientation="Horizontal"
                      Spacing="4"
                      Margin="0,8,0,0"
                      IsVisible="{Binding HasMinimizedChildPanes}">
            <TextBlock Text="Minimized panes:"
                       Foreground="#8FA8BE"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <ItemsControl ItemsSource="{Binding MinimizedChildPanes}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="app:ChildPaneDescriptor"
                              x:CompileBindings="False">
                  <Button Classes="SidebarActionButton"
                          Content="{Binding Title}"
                          Command="{Binding DataContext.RestoreChildPaneFromTaskbarCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                          CommandParameter="{Binding Id}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- Child pane: Current State & Command Surface (shell.current) -->
          <Border Margin="0,10,0,0"
                  IsVisible="{Binding IsShellCurrentChildVisible}">
            <StackPanel Spacing="10">
              <!-- Current State -->
              <Expander IsExpanded="{Binding IsCurrentStateSectionExpanded, Mode=TwoWay}">
                <Expander.Header>
                  <DockPanel LastChildFill="True">
                    <StackPanel Spacing="2"
                                DockPanel.Dock="Left">
                      <TextBlock Text="Current State"
                                 FontSize="14"
                                 Foreground="#F4F7FB"
                                 FontWeight="SemiBold" />
                      <TextBlock Text="High-signal summaries stay easy to inspect during testing."
                                 Foreground="#8FA8BE"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Right"
                                Margin="6,0,0,0">
                      <Button Classes="SidebarActionButton"
                              Content="▲"
                              Width="24"
                              Height="20"
                              Command="{Binding MoveChildPaneUpCommand}"
                              CommandParameter="shell.current"
                              ToolTip.Tip="Move pane up" />
                      <Button Classes="SidebarActionButton"
                              Content="▼"
                              Width="24"
                              Height="20"
                              Command="{Binding MoveChildPaneDownCommand}"
                              CommandParameter="shell.current"
                              ToolTip.Tip="Move pane down" />
                      <Button Classes="SidebarActionButton"
                              Content="–"
                              Width="24"
                              Height="20"
                              Margin="6,0,0,0"
                              Command="{Binding MinimizeChildPaneCommand}"
                              CommandParameter="shell.current"
                              ToolTip.Tip="Minimize this pane" />
                    </StackPanel>
                  </DockPanel>
                </Expander.Header>
                <Border Margin="0,8,0,0"
                        Padding="10"
                        Background="#1A2430"
                        BorderBrush="#3A4D63"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding FocusSummary}"
                               Foreground="#F4F7FB"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding FocusOriginSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectionSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding FocusedTransformSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding InteractionModeSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding EnteredNodeSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GroupSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LinkSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding PanelSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BookmarkSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ViewSummary}"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding PaneStructureSummary}"
                               Foreground="#8FA8BE"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBox Classes="SidebarReadout activity"
                             Text="{Binding LastActivitySummary}" />
                  </StackPanel>
                </Border>
              </Expander>

              <!-- Command Surface -->
              <Expander IsExpanded="{Binding IsCommandSurfaceSectionExpanded, Mode=TwoWay}">
                <Expander.Header>
                  <StackPanel Spacing="2">
                    <TextBlock Text="Command Surface"
                               FontSize="14"
                               Foreground="#F4F7FB"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Compact fallback tools grouped around real interaction tasks; mirrors what right-click context surfaces expose in the 3D world."
                               Foreground="#8FA8BE"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Expander.Header>
                <Border Margin="0,8,0,0"
                        Padding="10"
                        Background="#16202A"
                        BorderBrush="#35506A"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Right-click context surfaces in the 3D viewport (background, node, link, group) are the primary way to invoke these commands in place; this toolbar is a secondary, always-visible command surface for the same interaction tasks."
                               Foreground="#A9C4DC"
                               FontSize="11"
                               TextWrapping="Wrap" />

                    <!-- Selection & Focus -->
                    <Expander IsExpanded="{Binding IsSelectionFocusGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Selection &amp; Focus"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Focus Node"
                                Command="{Binding FocusFirstNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Select Node"
                                Command="{Binding SelectFirstNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Clear Selection"
                                Command="{Binding ClearSelectionCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Focus Panel"
                                Command="{Binding FocusFirstPanelCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Select Panel"
                                Command="{Binding SelectFirstPanelCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- Links -->
                    <Expander IsExpanded="{Binding IsLinksGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Links"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Link Selected → Focused"
                                Command="{Binding ConnectFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Unlink Selected → Focused"
                                Command="{Binding UnlinkFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Clear Links"
                                Command="{Binding ClearLinksCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- Groups -->
                    <Expander IsExpanded="{Binding IsGroupsGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Groups"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Group Selection"
                                Command="{Binding GroupSelectionCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Add To Active Group"
                                Command="{Binding AddSelectionToActiveGroupCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Remove From Active Group"
                                Command="{Binding RemoveSelectionFromActiveGroupCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Delete Active Group"
                                Command="{Binding DeleteActiveGroupCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- History -->
                    <Expander IsExpanded="{Binding IsHistoryGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="History"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Undo"
                                Command="{Binding UndoLastCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- View -->
                    <Expander IsExpanded="{Binding IsViewGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="View"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Home View"
                                Command="{Binding HomeViewCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Center Focused Node"
                                Command="{Binding CenterFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Frame Selection"
                                Command="{Binding FrameSelectionCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Enter Focused Node"
                                Command="{Binding EnterFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Exit Node"
                                Command="{Binding ExitNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Save Bookmark"
                                Command="{Binding SaveBookmarkCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Restore Bookmark"
                                Command="{Binding RestoreLatestBookmarkCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- Edit Modes -->
                    <Expander IsExpanded="{Binding IsEditModesGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Edit Modes"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <TextBlock Text="{Binding InteractionModeSummary}"
                                   Foreground="#8FA8BE"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                        <Button Classes="SidebarActionButton"
                                Content="Navigate Mode"
                                Command="{Binding ActivateNavigateModeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Move Mode"
                                Command="{Binding ActivateMoveModeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Marquee Mode"
                                Command="{Binding ActivateMarqueeModeCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- Mutation -->
                    <Expander IsExpanded="{Binding IsMutationGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Mutation"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
                      </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Create Node"
                                Command="{Binding CreateDemoNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Left"
                                Command="{Binding NudgeFocusedLeftCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Right"
                                Command="{Binding NudgeFocusedRightCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Up"
                                Command="{Binding NudgeFocusedUpCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Down"
                                Command="{Binding NudgeFocusedDownCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Forward"
                                Command="{Binding NudgeFocusedForwardCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Nudge Targets Back"
                                Command="{Binding NudgeFocusedBackCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Grow Targets"
                                Command="{Binding GrowFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Shrink Targets"
                                Command="{Binding ShrinkFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Delete Targets"
                                Command="{Binding DeleteFocusedNodeCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Attach Metadata Panelette"
                                Command="{Binding AttachDemoPanelCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Attach Label Panelette"
                                Command="{Binding AttachLabelPaneletteCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Attach Detailed Metadata Panelette"
                                Command="{Binding AttachDetailMetadataPaneletteCommand}" />
                      </StackPanel>
                    </Expander>

                    <!-- Appearance -->
                    <Expander IsExpanded="{Binding IsAppearanceGroupExpanded, Mode=TwoWay}">
                      <Expander.Header>
                        <TextBlock Text="Appearance"
                                   Foreground="#9FD3FF"
                                   FontWeight="SemiBold" />
            </Expander.Header>
                      <StackPanel Margin="12,6,0,0"
                                  Spacing="6">
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Triangle"
                                Command="{Binding ApplyTrianglePrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Square"
                                Command="{Binding ApplySquarePrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Diamond"
                                Command="{Binding ApplyDiamondPrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Pentagon"
                                Command="{Binding ApplyPentagonPrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Hexagon"
                                Command="{Binding ApplyHexagonPrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Cube"
                                Command="{Binding ApplyCubePrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Tetrahedron"
                                Command="{Binding ApplyTetrahedronPrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Sphere"
                                Command="{Binding ApplySpherePrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Primitive Box"
                                Command="{Binding ApplyBoxPrimitiveCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Fill Blue"
                                Command="{Binding ApplyBlueAppearanceCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Fill Violet"
                                Command="{Binding ApplyVioletAppearanceCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Fill Green"
                                Command="{Binding ApplyGreenAppearanceCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Increase Opacity"
                                Command="{Binding IncreaseOpacityCommand}" />
                        <Button Classes="SidebarActionButton"
                                Content="Decrease Opacity"
                                Command="{Binding DecreaseOpacityCommand}" />
                      </StackPanel>
                    </Expander>
                  </StackPanel>
                </Border>
              </Expander>
            </StackPanel>
          </Border>

          <!-- Child pane: Settings (shell.settings) -->
          <Border Margin="0,10,0,0"
                  IsVisible="{Binding IsShellSettingsChildVisible}">
            <Expander IsExpanded="{Binding IsSettingsSectionExpanded, Mode=TwoWay}">
            <Expander.Header>
              <DockPanel LastChildFill="True">
                <StackPanel Spacing="2"
                            DockPanel.Dock="Left">
                  <TextBlock Text="Settings"
                             FontSize="14"
                             Foreground="#F4F7FB"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Runtime-tunable engine UI settings for focus behavior, node/group halos, background, link appearance, and in-world 2D surfaces."
                             Foreground="#8FA8BE"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            Margin="6,0,0,0">
                  <Button Classes="SidebarActionButton"
                          Content="▲"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneUpCommand}"
                          CommandParameter="shell.settings"
                          ToolTip.Tip="Move pane up" />
                  <Button Classes="SidebarActionButton"
                          Content="▼"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneDownCommand}"
                          CommandParameter="shell.settings"
                          ToolTip.Tip="Move pane down" />
                  <Button Classes="SidebarActionButton"
                          Content="⧉"
                          Width="24"
                          Height="20"
                          Command="{Binding FloatSettingsChildPaneCommand}"
                          ToolTip.Tip="Float this pane" />
                  <Button Classes="SidebarActionButton"
                          Content="–"
                          Width="24"
                          Height="20"
                          Margin="6,0,0,0"
                          Command="{Binding MinimizeChildPaneCommand}"
                          CommandParameter="shell.settings"
                          ToolTip.Tip="Minimize this pane" />
                </StackPanel>
              </DockPanel>
            </Expander.Header>
            <ContentControl Content="{Binding}"
                            ContentTemplate="{StaticResource ShellSettingsChildContentTemplate}" />
          </Expander>
          </Border>

          <!-- Child pane: Developer Readouts (shell.developer) -->
          <Border Margin="0,10,0,0"
                  IsVisible="{Binding IsShellDeveloperChildVisible}">
          <Expander IsExpanded="{Binding IsDeveloperReadoutsSectionExpanded, Mode=TwoWay}">
            <Expander.Header>
              <DockPanel LastChildFill="True">
                <StackPanel Spacing="2"
                            DockPanel.Dock="Left">
                  <TextBlock Text="Developer Readouts"
                             FontSize="14"
                             Foreground="#F4F7FB"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Detailed inspection data stays available for debugging and future feature work, but no longer dominates the default shell surface."
                             Foreground="#8FA8BE"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            Margin="6,0,0,0">
                  <Button Classes="SidebarActionButton"
                          Content="▲"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneUpCommand}"
                          CommandParameter="shell.developer"
                          ToolTip.Tip="Move pane up" />
                  <Button Classes="SidebarActionButton"
                          Content="▼"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneDownCommand}"
                          CommandParameter="shell.developer"
                          ToolTip.Tip="Move pane down" />
                  <Button Classes="SidebarActionButton"
                          Content="–"
                          Width="24"
                          Height="20"
                          Margin="6,0,0,0"
                          Command="{Binding MinimizeChildPaneCommand}"
                          CommandParameter="shell.developer"
                          ToolTip.Tip="Minimize this pane" />
                </StackPanel>
              </DockPanel>
            </Expander.Header>
            <Border Margin="0,8,0,0"
                    Padding="10"
                    Background="#1A2430"
                    BorderBrush="#3A4D63"
                    BorderThickness="1"
                    CornerRadius="6">
              <StackPanel Spacing="6">
                <TextBox Classes="SidebarReadout"
                         Text="{Binding InteractionSemanticsSummary}" />
                <TextBox Classes="SidebarReadout readiness"
                         Text="{Binding ActionReadinessSummary}" />
                <TextBlock Text="Recent command history"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding CommandHistorySummary}" />
                <TextBlock Text="{Binding FocusedTransformSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding FocusedTransformDetails}" />
                <TextBlock Text="{Binding ViewSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding ViewDetails}" />
                <TextBlock Text="Navigation history"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding NavigationHistorySummary}" />
                <TextBlock Text="{Binding BookmarkSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding BookmarkDetails}" />
                <TextBlock Text="{Binding GroupSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding GroupDetails}" />
                <TextBlock Text="{Binding LinkSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding LinkDetails}" />
                <TextBlock Text="{Binding PanelSummary}"
                           Foreground="#D9E2EC"
                           TextWrapping="Wrap" />
                <TextBox Classes="SidebarReadout"
                         Text="{Binding PanelDetails}" />
              </StackPanel>
            </Border>
          </Expander>
          </Border>

          <!-- Child pane: Engine Capabilities (shell.capabilities) -->
          <Border Margin="0,10,0,0"
                  IsVisible="{Binding IsShellCapabilitiesChildVisible}">
          <Expander IsExpanded="{Binding IsCapabilitiesSectionExpanded, Mode=TwoWay}">
            <Expander.Header>
              <DockPanel LastChildFill="True">
                <StackPanel Spacing="2"
                            DockPanel.Dock="Left">
                  <TextBlock Text="Engine Capabilities"
                             FontSize="14"
                             Foreground="#F4F7FB"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Core-owned registrations remain accessible for development and future plugin/panel work."
                             Foreground="#8FA8BE"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            Margin="6,0,0,0">
                  <Button Classes="SidebarActionButton"
                          Content="▲"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneUpCommand}"
                          CommandParameter="shell.capabilities"
                          ToolTip.Tip="Move pane up" />
                  <Button Classes="SidebarActionButton"
                          Content="▼"
                          Width="24"
                          Height="20"
                          Command="{Binding MoveChildPaneDownCommand}"
                          CommandParameter="shell.capabilities"
                          ToolTip.Tip="Move pane down" />
                  <Button Classes="SidebarActionButton"
                          Content="–"
                          Width="24"
                          Height="20"
                          Margin="6,0,0,0"
                          Command="{Binding MinimizeChildPaneCommand}"
                          CommandParameter="shell.capabilities"
                          ToolTip.Tip="Minimize this pane" />
                </StackPanel>
              </DockPanel>
            </Expander.Header>
            <Border Margin="0,8,0,0"
                    Padding="10"
                    Background="#18222D"
                    BorderBrush="#33485E"
                    BorderThickness="1"
                    CornerRadius="6">
              <ItemsControl ItemsSource="{Binding Capabilities}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="cap:EngineCapability">
                    <Border Margin="0,6,0,0"
                            Padding="10"
                            Background="#18222D"
                            BorderBrush="#33485E"
                            BorderThickness="1"
                            CornerRadius="6">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="#F4F7FB"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Category}"
                                   Foreground="#7DD3FC" />
                        <TextBlock Text="{Binding Key}"
                                   Foreground="#C7D2DE"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="11"
                                   Opacity="1.0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Provider, StringFormat=Provider: {0}}"
                                   Foreground="#D9E2EC"
                                   Opacity="1.0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Version, StringFormat=Version: {0}}"
                                   Foreground="#D9E2EC"
                                   Opacity="1.0" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </Expander>
          </Border>
        </StackPanel>
      </ScrollViewer>
      </Border>
    </DataTemplate>

    <!-- Reusable content template for the Settings child pane body. -->
    <DataTemplate x:Key="ShellSettingsChildContentTemplate"
                  x:DataType="app:MainWindowViewModel">
      <Border Margin="0,8,0,0"
              Padding="10"
              Background="#151E28"
              BorderBrush="#304055"
              BorderThickness="1"
              CornerRadius="6">
        <StackPanel Spacing="6">
          <CheckBox Content="Mouse leave clears focus to background"
                    IsChecked="{Binding MouseLeaveClearsFocus, Mode=TwoWay}"
                    Foreground="#F4F7FB" />
          <TextBlock Text="When enabled, moving the mouse off all viewport entities clears focus back to null/background. When disabled, the last focused node or panelette remains focused until changed via keyboard or explicit commands."
                     Foreground="#8FA8BE"
                     FontSize="11"
                     TextWrapping="Wrap" />

          <!-- Shell layout presets -->
          <TextBlock Text="Shell layout"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,6,0,0"
                      Spacing="4">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="SidebarActionButton"
                      Content="Reset Layout to Default"
                      Command="{Binding ResetLayoutToDefaultCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="SidebarActionButton"
                      Content="Save Layout"
                      Command="{Binding SaveLayoutPresetCommand}" />
              <Button Classes="SidebarActionButton"
                      Content="Restore Saved Layout"
                      Command="{Binding RestoreLayoutPresetCommand}" />
            </StackPanel>
          </StackPanel>

          <!-- Groups -->
          <TextBlock Text="Groups"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,8,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding GroupOverlayOpacity, StringFormat=Group overlay opacity: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0"
                    Maximum="1"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding GroupOverlayOpacity, Mode=TwoWay}" />
          </StackPanel>

          <!-- Node halos -->
          <TextBlock Text="Node focus and halo settings"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,6,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding NodeHighlightOpacity, StringFormat=Node highlight opacity: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0"
                    Maximum="1"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding NodeHighlightOpacity, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding NodeFocusHaloRadiusMultiplier, StringFormat=Focus halo radius x: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.5"
                    Maximum="3"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.25"
                    Value="{Binding NodeFocusHaloRadiusMultiplier, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding NodeSelectionHaloRadiusMultiplier, StringFormat=Selection halo radius x: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.5"
                    Maximum="3"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.25"
                    Value="{Binding NodeSelectionHaloRadiusMultiplier, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="Halo mode (2D / 3D / Both)"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <ComboBox ItemsSource="{Binding NodeHaloModeOptions}"
                      SelectedItem="{Binding NodeHaloMode, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="3D halo volume mode"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <ComboBox ItemsSource="{Binding NodeHaloOcclusionModeOptions}"
                      SelectedItem="{Binding NodeHaloOcclusionMode, Mode=TwoWay}" />
          </StackPanel>

          <!-- Background -->
          <TextBlock Text="Background"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,8,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding BackgroundAnimationSpeed, StringFormat=Background animation speed: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0"
                    Maximum="2"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding BackgroundAnimationSpeed, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,8,0,0"
                      Spacing="4">
            <TextBlock Text="Background presets"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="SidebarActionButton"
                      Content="Deep Space"
                      Command="{Binding ApplyBackgroundDeepSpaceCommand}" />
              <Button Classes="SidebarActionButton"
                      Content="Dusk"
                      Command="{Binding ApplyBackgroundDuskCommand}" />
              <Button Classes="SidebarActionButton"
                      Content="Paper"
                      Command="{Binding ApplyBackgroundPaperCommand}" />
            </StackPanel>
          </StackPanel>

          <!-- Links -->
          <TextBlock Text="Links"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,8,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding LinkStrokeThickness, StringFormat=Link stroke thickness: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.5"
                    Maximum="4"
                    SmallChange="0.1"
                    LargeChange="0.25"
                    TickFrequency="0.25"
                    Value="{Binding LinkStrokeThickness, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding LinkOpacity, StringFormat=Link opacity: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.1"
                    Maximum="1"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding LinkOpacity, Mode=TwoWay}" />
          </StackPanel>

          <!-- In-world 2D surfaces -->
          <TextBlock Text="In-world 2D surfaces (panelettes, context surfaces)"
                     Foreground="#C7D2DE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Margin="0,8,0,0"
                     TextWrapping="Wrap" />
          <StackPanel Margin="0,8,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding PaneletteBackgroundIntensity, StringFormat=Panelette intensity: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.25"
                    Maximum="2"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding PaneletteBackgroundIntensity, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Margin="0,4,0,0"
                      Spacing="4">
            <TextBlock Text="{Binding CommandSurfaceOverlayOpacity, StringFormat=Context-surface opacity: {0:0.00}}"
                       Foreground="#C7D2DE"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Slider Minimum="0.25"
                    Maximum="2"
                    SmallChange="0.05"
                    LargeChange="0.1"
                    TickFrequency="0.1"
                    Value="{Binding CommandSurfaceOverlayOpacity, Mode=TwoWay}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.SidebarActionButton">
      <Setter Property="Foreground" Value="#F7FBFF" />
      <Setter Property="Background" Value="#2A5F8A" />
      <Setter Property="BorderBrush" Value="#7DCBFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.SidebarActionButton:pointerover">
      <Setter Property="Background" Value="#3476AB" />
      <Setter Property="BorderBrush" Value="#A7DFFF" />
    </Style>

    <Style Selector="Button.SidebarActionButton:pressed">
      <Setter Property="Background" Value="#214C6D" />
      <Setter Property="BorderBrush" Value="#D5F0FF" />
    </Style>

    <Style Selector="Button.SidebarActionButton:disabled">
      <Setter Property="Foreground" Value="#AAB7C4" />
      <Setter Property="Background" Value="#1A2733" />
      <Setter Property="BorderBrush" Value="#314658" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="TextBox.SidebarReadout">
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="Background" Value="#101821" />
      <Setter Property="Foreground" Value="#B9C7D6" />
      <Setter Property="BorderBrush" Value="#33485E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="TextBox.SidebarReadout.activity">
      <Setter Property="Foreground" Value="#8BE9A8" />
    </Style>

    <Style Selector="TextBox.SidebarReadout.readiness">
      <Setter Property="Foreground" Value="#9FD3FF" />
    </Style>
  </Window.Styles>

  <!-- 3-column, 3-row layout: left/right parents, top header, center viewport, optional bottom parent, floating overlay -->
  <Grid ColumnDefinitions="Auto,*,Auto"
        RowDefinitions="Auto,*,Auto">

    <!-- Left parent-pane host -->
    <Border x:Name="LeftPaneHost"
            Grid.RowSpan="3"
            Grid.Column="0"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,0,1,0"
            Padding="14"
            IsVisible="{Binding IsShellPaneOnLeft}">
      <ContentControl Content="{Binding}"
                      ContentTemplate="{StaticResource ShellPaneContentTemplate}" />
    </Border>

    <!-- Floating Settings child-pane host overlaying the viewport -->
    <Border x:Name="FloatingSettingsChildHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="40,40,40,40"
            Background="#101821CC"
            BorderBrush="#304055"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            IsVisible="{Binding IsSettingsChildFloating}">
      <StackPanel Spacing="6">
        <DockPanel LastChildFill="True">
          <StackPanel Spacing="2"
                      DockPanel.Dock="Left">
            <TextBlock Text="Settings"
                       FontSize="14"
                       Foreground="#F4F7FB"
                       FontWeight="SemiBold" />
            <TextBlock Text="Floating Settings pane — same engine UI controls, detached from the shell parent pane."
                       Foreground="#8FA8BE"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Orientation="Horizontal"
                      Spacing="4"
                      HorizontalAlignment="Right"
                      Margin="6,0,0,0">
            <Button Classes="SidebarActionButton"
                    Content="Dock"
                    Width="44"
                    Height="20"
                    Command="{Binding DockSettingsChildPaneCommand}"
                    ToolTip.Tip="Dock this pane back into the shell" />
          </StackPanel>
        </DockPanel>

        <ContentControl Content="{Binding}"
                        ContentTemplate="{StaticResource ShellSettingsChildContentTemplate}" />
      </StackPanel>
    </Border>

    <!-- Top parent-pane host (viewport header + optional shell when docked top) -->
    <Border x:Name="TopPaneHost"
            Grid.Column="1"
            Grid.Row="0"
            Padding="12,10,12,6">
      <StackPanel Spacing="4">
        <TextBlock Text="Constellate — Hybrid 2D/3D shell with Core capability registry"
                   FontSize="16"
                   FontWeight="SemiBold" />
        <TextBlock Text="Viewport: Right-click background/node/link/group opens context surfaces for create/clear/view/mode/link/group actions • Navigate mode = click/select + left-drag orbit; Shift+Left-drag or Right/Middle-drag = pan • Move mode = left-drag repositions the focused/selected node set with transient preview and release-time commit; Esc cancels a live drag without committing • Marquee mode = left-drag box select (Shift additive) • In Navigate mode, Alt+Left-drag = planar move and Space+Left-drag = depth move using the same move-commit path • Ctrl+Click or Double-Click other node = directed link from selected/focused source to clicked target in Navigate mode • Tab / Shift+Tab = cycle focus • Enter or Space = select (Shift additive) • Ctrl+Z = undo • Esc backs out of overlays/drags then clears selection • sidebar command groups mirror these actions and are collapsible"
                   FontSize="12"
                   Foreground="#8FA8BE"
                   TextWrapping="Wrap" />
        <ContentControl IsVisible="{Binding IsShellPaneOnTop}"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource ShellPaneContentTemplate}" />
      </StackPanel>
    </Border>

    <!-- Right parent-pane host -->
    <Border x:Name="RightPaneHost"
            Grid.RowSpan="3"
            Grid.Column="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="1,0,0,0"
            Padding="14"
            IsVisible="{Binding IsShellPaneOnRight}">
      <ContentControl Content="{Binding}"
                      ContentTemplate="{StaticResource ShellPaneContentTemplate}" />
    </Border>

    <!-- Center viewport host -->
    <Border x:Name="CenterViewportHost"
            Grid.Column="1"
            Grid.Row="1">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Bottom parent-pane host -->
    <Border x:Name="BottomPaneHost"
            Grid.Column="1"
            Grid.Row="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,1,0,0"
            Padding="10,6,10,10"
            IsVisible="{Binding IsShellPaneOnBottom}">
      <ContentControl Content="{Binding}"
                      ContentTemplate="{StaticResource ShellPaneContentTemplate}" />
    </Border>

    <!-- Floating parent-pane host overlaying the viewport -->
    <Border x:Name="FloatingPaneHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0"
            CornerRadius="8"
            Padding="0"
            IsVisible="{Binding IsShellPaneFloating}">
      <ContentControl Content="{Binding}"
                      ContentTemplate="{StaticResource ShellPaneContentTemplate}" />
    </Border>

    <!-- Edge restore tab for minimized shell pane -->
    <Button Grid.RowSpan="3"
            Grid.Column="0"
            Content="Shell"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Margin="4"
            Command="{Binding RestoreShellPaneCommand}"
            IsVisible="{Binding IsShellPaneMinimized}" />
  </Grid>
</Window>
