<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        x:Class="Constellate.App.MainWindow"
        Width="1000" Height="700"
        Title="Constellate — Hybrid 2D/3D">
  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
    <TextBlock Margin="8" Text="Constellate — Placeholder 3D viewport (OpenTK target)" />
    <rt:OpenTkViewportControl Grid.Row="1" />
  </Grid>
</Window>
