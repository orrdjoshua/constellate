<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        xmlns:app="clr-namespace:Constellate.App"
        xmlns:cap="clr-namespace:Constellate.Core.Capabilities;assembly=Constellate.Core"
        xmlns:style="clr-namespace:Avalonia.Styling;assembly=Avalonia"
        xmlns:ctrl="clr-namespace:Constellate.App.Controls"
        x:Class="Constellate.App.MainWindow"
        x:DataType="app:MainWindowViewModel"
        Width="1200"
        Height="760"
        Title="Constellate — Hybrid 2D/3D">

  <Window.Resources>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Polygon#TopLeft_LeftTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopLeft_LeftTriangle.hasMinLeft">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <!-- Visible (expanded) cyan state for LEFT host -->
    <Style Selector="Polygon#TopLeft_LeftTriangle.hasVisibleLeft">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomLeft_LeftTriangle.hasVisibleLeft">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#BottomLeft_LeftTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomLeft_LeftTriangle.hasMinLeft">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#TopLeft_TopTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopLeft_TopTriangle.hasMinTop">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <!-- Visible (expanded) cyan state for TOP host -->
    <Style Selector="Polygon#TopLeft_TopTriangle.hasVisibleTop">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#TopRight_TopTriangle.hasVisibleTop">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#TopRight_TopTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopRight_TopTriangle.hasMinTop">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#TopRight_RightTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopRight_RightTriangle.hasMinRight">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <!-- Visible (expanded) cyan state for RIGHT host -->
    <Style Selector="Polygon#TopRight_RightTriangle.hasVisibleRight">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomRight_RightTriangle.hasVisibleRight">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#BottomRight_RightTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomRight_RightTriangle.hasMinRight">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#BottomLeft_BottomTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomLeft_BottomTriangle.hasMinBottom">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <!-- Visible (expanded) cyan state for BOTTOM host -->
    <Style Selector="Polygon#BottomLeft_BottomTriangle.hasVisibleBottom">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomRight_BottomTriangle.hasVisibleBottom">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#BottomRight_BottomTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomRight_BottomTriangle.hasMinBottom">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <!-- New: general hover affordance for all corner triangles -->
    <Style Selector="Polygon.cornerAff">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Polygon.cornerAff:pointerover">
      <Setter Property="StrokeThickness" Value="2"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>
  </Window.Styles>

  <Grid x:Name="RootGrid"
        Background="#050911">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Left parent-pane host -->
    <Border x:Name="LeftPaneHost"
            Grid.Row="{Binding LeftPaneRow}"
            Grid.RowSpan="{Binding LeftPaneRowSpan}"
            Grid.Column="0"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,0,1,0"
            Padding="14"
            MinWidth="260"
            IsVisible="{Binding IsShellPaneOnLeft}">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Minimize pane"
                    Command="{Binding MinimizeShellPaneCommand}"
                    CommandParameter="left" />
          <MenuItem Header="Destroy pane"
                    Command="{Binding DestroyParentPaneCommand}"
                    CommandParameter="left" />
          <Separator />
          <MenuItem Header="One column"
                    Command="{Binding SetLeftPaneSplitCommand}"
                    CommandParameter="1" />
          <MenuItem Header="Two columns"
                    Command="{Binding SetLeftPaneSplitCommand}"
                    CommandParameter="2" />
          <Separator />
          <MenuItem Header="Previous slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="left:prev" />
          <MenuItem Header="Next slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="left:next" />
        </ContextMenu>
      </Border.ContextMenu>

      <ItemsControl ItemsSource="{Binding ParentPaneModelsLeft}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ctrl:ParentPaneView/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- Top parent-pane host -->
    <Border x:Name="TopPaneHost"
            Grid.Column="{Binding TopPaneColumn}"
            Grid.ColumnSpan="{Binding TopPaneColumnSpan}"
            Grid.Row="0"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,0,0,1"
            Padding="10,6,10,4"
            MinHeight="220"
            IsVisible="{Binding IsShellPaneOnTop}">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Minimize pane"
                    Command="{Binding MinimizeShellPaneCommand}"
                    CommandParameter="top" />
          <MenuItem Header="Destroy pane"
                    Command="{Binding DestroyParentPaneCommand}"
                    CommandParameter="top" />
          <Separator />
          <MenuItem Header="One row"
                    Command="{Binding SetTopPaneSplitCommand}"
                    CommandParameter="1" />
          <MenuItem Header="Two rows"
                    Command="{Binding SetTopPaneSplitCommand}"
                    CommandParameter="2" />
          <Separator />
          <MenuItem Header="Previous slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="top:prev" />
          <MenuItem Header="Next slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="top:next" />
        </ContextMenu>
      </Border.ContextMenu>

      <ItemsControl ItemsSource="{Binding ParentPaneModelsTop}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ctrl:ParentPaneView/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- Right parent-pane host -->
    <Border x:Name="RightPaneHost"
            Grid.Row="{Binding RightPaneRow}"
            Grid.RowSpan="{Binding RightPaneRowSpan}"
            Grid.Column="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="1,0,0,0"
            Padding="14"
            MinWidth="260"
            IsVisible="{Binding IsRightPaneHostVisible}">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Minimize pane"
                    Command="{Binding MinimizeShellPaneCommand}"
                    CommandParameter="right" />
          <MenuItem Header="Destroy pane"
                    Command="{Binding DestroyParentPaneCommand}"
                    CommandParameter="right" />
          <Separator />
          <MenuItem Header="One column"
                    Command="{Binding SetRightPaneSplitCommand}"
                    CommandParameter="1" />
          <MenuItem Header="Two columns"
                    Command="{Binding SetRightPaneSplitCommand}"
                    CommandParameter="2" />
          <Separator />
          <MenuItem Header="Previous slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="right:prev" />
          <MenuItem Header="Next slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="right:next" />
        </ContextMenu>
      </Border.ContextMenu>

      <ItemsControl ItemsSource="{Binding ParentPaneModelsRight}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ctrl:ParentPaneView/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- Center viewport host -->
    <Border x:Name="CenterViewportHost"
            Grid.Column="1"
            Grid.Row="1">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Bottom parent-pane host -->
    <Border x:Name="BottomPaneHost"
            Grid.Column="{Binding BottomPaneColumn}"
            Grid.ColumnSpan="{Binding BottomPaneColumnSpan}"
            Grid.Row="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,1,0,0"
            Padding="10,6,10,10"
            MinHeight="220"
            IsVisible="{Binding IsShellPaneOnBottom}">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Minimize pane"
                    Command="{Binding MinimizeShellPaneCommand}"
                    CommandParameter="bottom" />
          <MenuItem Header="Destroy pane"
                    Command="{Binding DestroyParentPaneCommand}"
                    CommandParameter="bottom" />
          <Separator />
          <MenuItem Header="One row"
                    Command="{Binding SetBottomPaneSplitCommand}"
                    CommandParameter="1" />
          <MenuItem Header="Two rows"
                    Command="{Binding SetBottomPaneSplitCommand}"
                    CommandParameter="2" />
          <Separator />
          <MenuItem Header="Previous slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="bottom:prev" />
          <MenuItem Header="Next slide"
                    Command="{Binding SlideParentPaneCommand}"
                    CommandParameter="bottom:next" />
        </ContextMenu>
      </Border.ContextMenu>

      <ItemsControl ItemsSource="{Binding ParentPaneModelsBottom}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ctrl:ParentPaneView/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- Floating parent-pane host -->
    <Border x:Name="FloatingPaneHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0"
            CornerRadius="8"
            Padding="0"
            IsVisible="{Binding IsShellPaneFloating}">
      <Border.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Minimize pane"
                    Command="{Binding MinimizeShellPaneCommand}"
                    CommandParameter="floating" />
          <MenuItem Header="Destroy pane"
                    Command="{Binding DestroyParentPaneCommand}"
                    CommandParameter="floating" />
        </ContextMenu>
      </Border.ContextMenu>

      <Canvas>
        <ItemsControl ItemsSource="{Binding ParentPaneModelsFloating}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <!-- Retain floating geometry and preserve double-tap restore via MainWindow handler -->
              <Grid RowDefinitions="Auto,*"
                    Width="{Binding FloatingWidth}"
                    Canvas.Left="{Binding FloatingX}"
                    Canvas.Top="{Binding FloatingY}"
                    DoubleTapped="OnFloatingParentHeaderDoubleTapped">
                <ctrl:ParentPaneView/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Parentless floating child panes -->
        <ItemsControl ItemsSource="{Binding FloatingChildPanes}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="app:ChildPaneDescriptor">
              <Grid RowDefinitions="Auto,*"
                    Width="{Binding FloatingWidth}"
                    Height="{Binding FloatingHeight}"
                    Canvas.Left="{Binding FloatingX}"
                    Canvas.Top="{Binding FloatingY}">
                <ctrl:ChildPaneView/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Canvas>
    </Border>

    <!-- Corner affordances (triangles) -->
    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="44"
            Height="44"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="6"
            Panel.ZIndex="1000">
      <Polygon x:Name="TopLeft_LeftTriangle"
               Points="0,0 14,14 0,28"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="left"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinLeft="{Binding HasMinimizedParentLeft}"
               Classes.hasVisibleLeft="{Binding IsShellPaneOnLeft}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Left pane" />
        </ToolTip.Tip>
      </Polygon>
      <Polygon x:Name="TopLeft_TopTriangle"
               Points="0,0 28,0 14,14"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="top"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinTop="{Binding HasMinimizedParentTop}"
               Classes.hasVisibleTop="{Binding IsShellPaneOnTop}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Top pane" />
        </ToolTip.Tip>
      </Polygon>
    </Canvas>

    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="44"
            Height="44"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="6"
            Panel.ZIndex="1000">
      <Polygon x:Name="TopRight_TopTriangle"
               Points="44,0 16,0 30,14"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="top"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinTop="{Binding HasMinimizedParentTop}"
               Classes.hasVisibleTop="{Binding IsShellPaneOnTop}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Top pane" />
        </ToolTip.Tip>
      </Polygon>
      <Polygon x:Name="TopRight_RightTriangle"
               Points="44,0 30,14 44,28"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="right"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinRight="{Binding HasMinimizedParentRight}"
               Classes.hasVisibleRight="{Binding IsShellPaneOnRight}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Right pane" />
        </ToolTip.Tip>
      </Polygon>
    </Canvas>

    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="44"
            Height="44"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="6"
            Panel.ZIndex="1000">
      <Polygon x:Name="BottomLeft_LeftTriangle"
               Points="0,44 14,30 0,16"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="left"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinLeft="{Binding HasMinimizedParentLeft}"
               Classes.hasVisibleLeft="{Binding IsShellPaneOnLeft}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Left pane" />
        </ToolTip.Tip>
      </Polygon>
      <Polygon x:Name="BottomLeft_BottomTriangle"
               Points="0,44 28,44 14,30"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="bottom"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinBottom="{Binding HasMinimizedParentBottom}"
               Classes.hasVisibleBottom="{Binding IsShellPaneOnBottom}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Bottom pane" />
        </ToolTip.Tip>
      </Polygon>
    </Canvas>

    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            Width="44"
            Height="44"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="6"
            Panel.ZIndex="1000">
      <Polygon x:Name="BottomRight_BottomTriangle"
               Points="44,44 16,44 30,30"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="bottom"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinBottom="{Binding HasMinimizedParentBottom}"
               Classes.hasVisibleBottom="{Binding IsShellPaneOnBottom}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Bottom pane" />
        </ToolTip.Tip>
      </Polygon>
      <Polygon x:Name="BottomRight_RightTriangle"
               Points="44,44 30,30 44,16"
               Stroke="#E5EDF7"
               StrokeThickness="1.2"
               Cursor="Hand"
               Tag="right"
               Classes="cornerAff"
               PointerPressed="CornerTriangle_OnPointerPressed"
               Classes.hasMinRight="{Binding HasMinimizedParentRight}"
               Classes.hasVisibleRight="{Binding IsShellPaneOnRight}">
        <ToolTip.Tip>
          <TextBlock Text="Create or restore Right pane" />
        </ToolTip.Tip>
      </Polygon>
    </Canvas>

    <!-- Top-corner intersection toggles -->
    <Border x:Name="TopLeftIntersectionHit"
            Grid.Row="0"
            Grid.Column="0"
            Width="10"
            Height="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0,0,2,2"
            IsVisible="{Binding IsShellPaneOnTop}"
            DoubleTapped="OnTopCornerIntersectionDoubleTapped" />
    <Border x:Name="TopRightIntersectionHit"
            Grid.Row="0"
            Grid.Column="2"
            Width="10"
            Height="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="2,0,0,2"
            IsVisible="{Binding IsShellPaneOnTop}"
            DoubleTapped="OnTopCornerIntersectionDoubleTapped" />

    <!-- Resize grips -->
    <Border x:Name="LeftPaneResizeGrip"
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Right"
            Width="8"
            Background="Transparent"
            Cursor="SizeWestEast"
            IsHitTestVisible="{Binding IsShellPaneOnLeft}"
            IsVisible="{Binding IsShellPaneOnLeft}" />
    <Border x:Name="RightPaneResizeGrip"
            Grid.Row="1"
            Grid.Column="2"
            HorizontalAlignment="Left"
            Width="8"
            Background="Transparent"
            Cursor="SizeWestEast"
            IsHitTestVisible="{Binding IsShellPaneOnRight}"
            IsVisible="{Binding IsShellPaneOnRight}" />
    <Border x:Name="TopPaneResizeGrip"
            Grid.Row="0"
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Height="8"
            Background="Transparent"
            Cursor="SizeNorthSouth"
            IsHitTestVisible="{Binding IsShellPaneOnTop}"
            IsVisible="{Binding IsShellPaneOnTop}" />
    <Border x:Name="BottomPaneResizeGrip"
            Grid.Row="2"
            Grid.Column="1"
            VerticalAlignment="Top"
            Height="8"
            Background="Transparent"
            Cursor="SizeNorthSouth"
            IsHitTestVisible="{Binding IsShellPaneOnBottom}"
            IsVisible="{Binding IsShellPaneOnBottom}" />

    <!-- Drag shadow overlays -->
    <!-- (debug HUD removed) -->

    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            IsHitTestVisible="False">
      <Border IsVisible="{Binding IsParentPaneDragShadowVisible}"
              Canvas.Left="{Binding ParentPaneDragShadowLeft}"
              Canvas.Top="{Binding ParentPaneDragShadowTop}"
              Width="{Binding ParentPaneDragShadowWidth}"
              Height="{Binding ParentPaneDragShadowHeight}"
              Background="#40FFFFFF"
              BorderBrush="#80FFFFFF"
              BorderThickness="2"
              CornerRadius="4" />
      <Border IsVisible="{Binding IsChildPaneDragShadowVisible}"
              Canvas.Left="{Binding ChildPaneDragShadowLeft}"
              Canvas.Top="{Binding ChildPaneDragShadowTop}"
              Width="{Binding ChildPaneDragShadowWidth}"
              Height="{Binding ChildPaneDragShadowHeight}"
              Background="#4040C0FF"
              BorderBrush="#80FFFFFF"
              BorderThickness="1.5"
              CornerRadius="3" />
    </Canvas>

    <!-- Bottom-corner intersection toggles -->
    <Border x:Name="BottomLeftIntersectionHit"
            Grid.Row="2"
            Grid.Column="0"
            Width="10"
            Height="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0,2,2,0"
            IsVisible="{Binding IsShellPaneOnBottom}"
            DoubleTapped="OnBottomCornerIntersectionDoubleTapped" />
    <Border x:Name="BottomRightIntersectionHit"
            Grid.Row="2"
            Grid.Column="2"
            Width="10"
            Height="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="2,2,0,0"
            IsVisible="{Binding IsShellPaneOnBottom}"
            DoubleTapped="OnBottomCornerIntersectionDoubleTapped" />
  </Grid>
</Window>
