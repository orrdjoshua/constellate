<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        xmlns:app="clr-namespace:Constellate.App"
        xmlns:cap="clr-namespace:Constellate.Core.Capabilities;assembly=Constellate.Core"
        x:Class="Constellate.App.MainWindow"
        x:DataType="app:MainWindowViewModel"
        Width="1200"
        Height="760"
        Title="Constellate — Hybrid 2D/3D">

  <!-- No legacy shell templates or styles; resources/styles are intentionally empty
       until the new generic parent-pane / 2D World design is introduced. -->
  <Window.Resources>
  </Window.Resources>

  <Window.Styles>
  </Window.Styles>

  <!-- 3-column, 3-row layout:
       - Left/right/top/bottom hosts are invisible parent-pane placeholders.
       - Center host contains the 3D viewport.
       - Floating host is an invisible overlay for future floating parent panes. -->
  <Grid ColumnDefinitions="Auto,*,Auto"
        RowDefinitions="Auto,*,Auto">

    <!-- Left parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="LeftPaneHost"
            Grid.RowSpan="3"
            Grid.Column="0"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,0,1,0"
            Padding="14"
            IsVisible="{Binding IsShellPaneOnLeft}">
    </Border>

    <!-- Top parent-pane host (no legacy header; reserved for future parent panes) -->
    <Border x:Name="TopPaneHost"
            Grid.Column="1"
            Grid.Row="0"
            Padding="0"
            IsVisible="{Binding IsShellPaneOnTop}">
    </Border>

    <!-- Right parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="RightPaneHost"
            Grid.RowSpan="3"
            Grid.Column="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="1,0,0,0"
            Padding="14"
            IsVisible="{Binding IsRightPaneHostVisible}">
    </Border>

    <!-- Center viewport host: pure 3D World -->
    <Border x:Name="CenterViewportHost"
            Grid.Column="1"
            Grid.Row="1">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Bottom parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="BottomPaneHost"
            Grid.Column="1"
            Grid.Row="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,1,0,0"
            Padding="10,6,10,10"
            IsVisible="{Binding IsShellPaneOnBottom}">
    </Border>

    <!-- Floating parent-pane host overlaying the viewport (for future floating panes) -->
    <Border x:Name="FloatingPaneHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0"
            CornerRadius="8"
            Padding="0"
            IsVisible="{Binding IsShellPaneFloating}">
    </Border>

    <!-- Corner affordances: small always-visible controls to create/restore parent panes.
         Top-left: create/restore Left and Top panes.
         Top-right: create/restore Top and Right panes.
         Bottom-left: create/restore Left and Bottom panes.
         Bottom-right: create/restore Bottom and Right panes. -->

    <!-- Top-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
    </StackPanel>

    <!-- Top-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬅"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
    </StackPanel>

    <!-- Bottom-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬆"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Bottom pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="bottom" />
    </StackPanel>

    <!-- Bottom-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬆"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
      <Button Width="22"
              Height="22"
              Content="⬅"
              ToolTip.Tip="Create or restore Bottom pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="bottom" />
    </StackPanel>
  </Grid>
</Window>
