<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        xmlns:app="clr-namespace:Constellate.App"
        xmlns:cap="clr-namespace:Constellate.Core.Capabilities;assembly=Constellate.Core"
        x:Class="Constellate.App.MainWindow"
        x:DataType="app:MainWindowViewModel"
        Width="1200"
        Height="760"
        Title="Constellate — Hybrid 2D/3D">

  <!-- No legacy shell templates or styles; resources/styles are intentionally empty
       until the new generic parent-pane / 2D World design is introduced. -->
  <Window.Resources>
  </Window.Resources>

  <Window.Styles>
  </Window.Styles>

  <!-- 3-column, 3-row layout:
       - Left/right/top/bottom hosts are invisible parent-pane placeholders.
       - Center host contains the 3D viewport.
       - Floating host is an invisible overlay for future floating parent panes. -->
  <Grid ColumnDefinitions="Auto,*,Auto"
        RowDefinitions="Auto,*,Auto">

    <!-- Left parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="LeftPaneHost"
            Grid.RowSpan="3"
            Grid.Column="0"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,0,1,0"
            Padding="14"
            IsVisible="{Binding IsShellPaneOnLeft}">
      <Grid>
        <!-- Simple parent-pane header/chrome with label + minimize/close -->
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4"
                Margin="0,0,0,8">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>


        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Top parent-pane host (no legacy header; reserved for future parent panes) -->
    <Border x:Name="TopPaneHost"
            Grid.Column="1"
            Grid.Row="0"
            Padding="10,6,10,4"
            IsVisible="{Binding IsShellPaneOnTop}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Top parent-pane host (no legacy header; reserved for future parent panes) -->
    <Border x:Name="TopPaneHost"
            Grid.Column="1"
            Grid.Row="0"
            Padding="10,6,10,4"
            IsVisible="{Binding IsShellPaneOnTop}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4">
    <!-- Right parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="RightPaneHost"
            Grid.RowSpan="3"
            Grid.Column="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="1,0,0,0"
            Padding="14"
            IsVisible="{Binding IsRightPaneHostVisible}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4"
                Margin="0,0,0,8">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Right parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="RightPaneHost"
            Grid.RowSpan="3"
            Grid.Column="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="1,0,0,0"
            Padding="14"
            IsVisible="{Binding IsRightPaneHostVisible}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4"
                Margin="0,0,0,8">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Center viewport host: pure 3D World -->
    <Border x:Name="CenterViewportHost"
            Grid.Column="1"
            Grid.Row="1">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Bottom parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="BottomPaneHost"
            Grid.Column="1"
            Grid.Row="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,1,0,0"
            Padding="10,6,10,10"
            IsVisible="{Binding IsShellPaneOnBottom}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Floating parent-pane host overlaying the viewport (for future floating panes) -->
    <Border x:Name="FloatingPaneHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0"
            CornerRadius="8"
            Padding="0"
            IsVisible="{Binding IsShellPaneFloating}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4"
                Margin="0,0,0,8">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the floating parent pane -->
      </Grid>
    </Border>

    <!-- Corner affordances: small always-visible controls to create/restore parent panes.
         Top-left: create/restore Left and Top panes.
         Top-right: create/restore Top and Right panes.
         Bottom-left: create/restore Left and Bottom panes.
         Bottom-right: create/restore Bottom and Right panes. -->

    <!-- Top-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
    <!-- Center viewport host: pure 3D World -->
    <Border x:Name="CenterViewportHost"
            Grid.Column="1"
            Grid.Row="1">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Bottom parent-pane host (reserved for future generic parent panes) -->
    <Border x:Name="BottomPaneHost"
            Grid.Column="1"
            Grid.Row="2"
            Background="#0E141B"
            BorderBrush="#2A394B"
            BorderThickness="0,1,0,0"
            Padding="10,6,10,10"
            IsVisible="{Binding IsShellPaneOnBottom}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the parent pane -->
      </Grid>
    </Border>

    <!-- Floating parent-pane host overlaying the viewport (for future floating panes) -->
    <Border x:Name="FloatingPaneHost"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40"
            Background="Transparent"
            BorderBrush="#2A394B"
            BorderThickness="0"
            CornerRadius="8"
            Padding="0"
            IsVisible="{Binding IsShellPaneFloating}">
      <Grid>
        <Border Background="#121A23"
                CornerRadius="4"
                Padding="6,4"
                Margin="0,0,0,8">
          <DockPanel LastChildFill="False">
            <TextBlock Text="Parent Pane"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#E5EDF7"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="–"
                      ToolTip.Tip="Minimize pane"
                      Command="{Binding MinimizeShellPaneCommand}" />
              <Button Width="20"
                      Height="20"
                      Padding="0"
                      Content="×"
                      ToolTip.Tip="Close pane"
                      Command="{Binding DestroyParentPaneCommand}" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Placeholder for future child-pane content inside the floating parent pane -->
      </Grid>
    </Border>

    <!-- Corner affordances: small always-visible controls to create/restore parent panes.
         Top-left: create/restore Left and Top panes.
         Top-right: create/restore Top and Right panes.
         Bottom-left: create/restore Left and Bottom panes.
         Bottom-right: create/restore Bottom and Right panes. -->

    <!-- Top-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
    </StackPanel>

    <!-- Top-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
    </StackPanel>

    <!-- Top-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
              Content="⬅"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
    </StackPanel>

    <!-- Bottom-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬅"
              ToolTip.Tip="Create or restore Top pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="top" />
      <Button Width="22"
              Height="22"
              Content="⬇"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
    </StackPanel>

    <!-- Bottom-left corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
              Content="⬆"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Bottom pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="bottom" />
    </StackPanel>

    <!-- Bottom-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬆"
              ToolTip.Tip="Create or restore Left pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="left" />
      <Button Width="22"
              Height="22"
              Content="➡"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
      <Button Width="22"
              Height="22"
              Content="⬅"
              ToolTip.Tip="Create or restore Bottom pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="bottom" />
    </StackPanel>

    <!-- Bottom-right corner -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="6"
                Spacing="4">
      <Button Width="22"
              Height="22"
              Content="⬆"
              ToolTip.Tip="Create or restore Right pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="right" />
      <Button Width="22"
              Height="22"
              Content="⬅"
              ToolTip.Tip="Create or restore Bottom pane"
              Command="{Binding CreateOrRestoreParentPaneCommand}"
              CommandParameter="bottom" />
    </StackPanel>
    <!-- Drag shadow overlay for parent-pane drag preview -->
    <Canvas Grid.RowSpan="3"
            Grid.ColumnSpan="3"
            IsHitTestVisible="False">
      <Border IsVisible="{Binding IsParentPaneDragShadowVisible}"
              Canvas.Left="{Binding ParentPaneDragShadowLeft}"
              Canvas.Top="{Binding ParentPaneDragShadowTop}"
              Width="{Binding ParentPaneDragShadowWidth}"
              Height="{Binding ParentPaneDragShadowHeight}"
              Background="#40FFFFFF"
              BorderBrush="#80FFFFFF"
              BorderThickness="2"
              CornerRadius="4" />
    </Canvas>
  </Grid>
</Window>