<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rt="clr-namespace:Constellate.Renderer.OpenTK.Controls;assembly=Constellate.Renderer.OpenTK"
        xmlns:app="clr-namespace:Constellate.App"
        xmlns:ctrl="clr-namespace:Constellate.App.Controls"
        x:Class="Constellate.App.MainWindow"
        x:DataType="app:MainWindowViewModel"
        Width="1200"
        Height="760"
        Title="Constellate — Hybrid 2D/3D">

  <Window.Styles>
    <!-- Overlay dock-resize grip hover affordances -->
    <Style Selector="Border#OverlayLeftResizeGrip:pointerover, Border#OverlayRightResizeGrip:pointerover, Border#OverlayTopResizeGrip:pointerover, Border#OverlayBottomResizeGrip:pointerover">
      <Setter Property="Background" Value="#20313A46"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <!-- Corner intersection hit-target hover -->
    <Style Selector="Border#OverlayCornerTopLeft:pointerover, Border#OverlayCornerTopRight:pointerover, Border#OverlayCornerBottomLeft:pointerover, Border#OverlayCornerBottomRight:pointerover">
      <Setter Property="Background" Value="#20313A46"/>
      <Setter Property="BorderBrush" Value="#FFC48A2F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <!-- Corner affordance styles (unchanged) -->
    <Style Selector="Polygon.cornerAff">
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Polygon.cornerAff:pointerover">
      <Setter Property="StrokeThickness" Value="2"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <!-- Hover highlight for triangle states (same as before) -->
    <Style Selector="Polygon#TopLeft_LeftTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopLeft_LeftTriangle.hasMinLeft">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <Style Selector="Polygon#TopLeft_LeftTriangle.hasVisibleLeft">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomLeft_LeftTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomLeft_LeftTriangle.hasMinLeft">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#TopLeft_TopTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopLeft_TopTriangle.hasMinTop">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <Style Selector="Polygon#TopLeft_TopTriangle.hasVisibleTop">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#TopRight_TopTriangle.hasVisibleTop">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#TopRight_TopTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopRight_TopTriangle.hasMinTop">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#TopRight_RightTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#TopRight_RightTriangle.hasMinRight">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <Style Selector="Polygon#TopRight_RightTriangle.hasVisibleRight">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomRight_RightTriangle.hasVisibleRight">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#BottomRight_RightTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomRight_RightTriangle.hasMinRight">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>

    <Style Selector="Polygon#BottomLeft_BottomTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomLeft_BottomTriangle.hasMinBottom">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
    <Style Selector="Polygon#BottomLeft_BottomTriangle.hasVisibleBottom">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>
    <Style Selector="Polygon#BottomRight_BottomTriangle.hasVisibleBottom">
      <Setter Property="Fill" Value="#00D3FF" />
    </Style>

    <Style Selector="Polygon#BottomRight_BottomTriangle">
      <Setter Property="Fill" Value="#60313A46" />
    </Style>
    <Style Selector="Polygon#BottomRight_BottomTriangle.hasMinBottom">
      <Setter Property="Fill" Value="#FFC48A2F" />
    </Style>
  </Window.Styles>

  <!-- Root grid remains only as a neutral root to layer viewport (below) and overlay (above). -->
  <Grid x:Name="RootGrid" Background="#050911">
    <!-- Layer 0: Full-window 3D viewport -->
    <Border x:Name="ViewportHost"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <rt:OpenTkViewportControl />
    </Border>

    <!-- Layer 1+: Unified 2D overlay (hit-testable only where controls exist) -->
    <Grid x:Name="OverlayRoot"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          IsHitTestVisible="True"
          ZIndex="900">

      <!-- Unified overlay: docked + floating in one layer -->
      <ctrl:OverlayPaneLayer DataContext="{Binding}"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             ZIndex="0" />

      <!-- Dock resize grips in overlay (gesture host binds to the Border names) -->
      <ctrl:OverlayResizeGripLayer DataContext="{Binding}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   ZIndex="10" />

      <!-- Drag shadow overlays (pointer-transparent) -->
      <Canvas IsHitTestVisible="False"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ClipToBounds="True"
              ZIndex="20">
        <Border IsVisible="{Binding IsParentPaneDragShadowVisible}"
                Canvas.Left="{Binding ParentPaneDragShadowLeft}"
                Canvas.Top="{Binding ParentPaneDragShadowTop}"
                Width="{Binding ParentPaneDragShadowWidth}"
                Height="{Binding ParentPaneDragShadowHeight}"
                Background="#40FFFFFF"
                BorderBrush="#80FFFFFF"
                BorderThickness="2"
                CornerRadius="4" />
        <Border IsVisible="{Binding IsChildPaneDragShadowVisible}"
                Canvas.Left="{Binding ChildPaneDragShadowLeft}"
                Canvas.Top="{Binding ChildPaneDragShadowTop}"
                Width="{Binding ChildPaneDragShadowWidth}"
                Height="{Binding ChildPaneDragShadowHeight}"
                Background="#4040C0FF"
                BorderBrush="#80FFFFFF"
                BorderThickness="1.5"
                CornerRadius="3" />
      </Canvas>

      <!-- Corner affordances: overlay, anchored to window corners -->
      <Canvas Width="44" Height="44"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="6"
              ZIndex="30">
        <Polygon x:Name="TopLeft_LeftTriangle"
                 Points="0,0 14,14 0,28"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="left"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinLeft="{Binding HasMinimizedParentLeft}"
                 Classes.hasVisibleLeft="{Binding IsShellPaneOnLeft}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Left pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
        <Polygon x:Name="TopLeft_TopTriangle"
                 Points="0,0 28,0 14,14"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="top"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinTop="{Binding HasMinimizedParentTop}"
                 Classes.hasVisibleTop="{Binding IsShellPaneOnTop}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Top pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
      </Canvas>

      <Canvas Width="44" Height="44"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="6"
              ZIndex="30">
        <Polygon x:Name="TopRight_TopTriangle"
                 Points="44,0 16,0 30,14"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="top"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinTop="{Binding HasMinimizedParentTop}"
                 Classes.hasVisibleTop="{Binding IsShellPaneOnTop}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Top pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
        <Polygon x:Name="TopRight_RightTriangle"
                 Points="44,0 30,14 44,28"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="right"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinRight="{Binding HasMinimizedParentRight}"
                 Classes.hasVisibleRight="{Binding IsShellPaneOnRight}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Right pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
      </Canvas>

      <Canvas Width="44" Height="44"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="6"
              ZIndex="30">
        <Polygon x:Name="BottomLeft_LeftTriangle"
                 Points="0,44 14,30 0,16"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="left"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinLeft="{Binding HasMinimizedParentLeft}"
                 Classes.hasVisibleLeft="{Binding IsShellPaneOnLeft}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Left pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
        <Polygon x:Name="BottomLeft_BottomTriangle"
                 Points="0,44 28,44 14,30"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="bottom"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinBottom="{Binding HasMinimizedParentBottom}"
                 Classes.hasVisibleBottom="{Binding IsShellPaneOnBottom}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Bottom pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
      </Canvas>

      <Canvas Width="44" Height="44"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="6"
              ZIndex="30">
        <Polygon x:Name="BottomRight_BottomTriangle"
                 Points="44,44 16,44 30,30"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="bottom"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinBottom="{Binding HasMinimizedParentBottom}"
                 Classes.hasVisibleBottom="{Binding IsShellPaneOnBottom}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Bottom pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
        <Polygon x:Name="BottomRight_RightTriangle"
                 Points="44,44 30,30 44,16"
                 Stroke="#E5EDF7"
                 StrokeThickness="1.2"
                 Cursor="Hand"
                 Tag="right"
                 Classes="cornerAff"
                 PointerPressed="CornerTriangle_OnPointerPressed"
                 Classes.hasMinRight="{Binding HasMinimizedParentRight}"
                 Classes.hasVisibleRight="{Binding IsShellPaneOnRight}">
          <ToolTip.Tip>
            <TextBlock Text="Create, restore, or re-expand the Right pane from this corner affordance." />
          </ToolTip.Tip>
        </Polygon>
      </Canvas>

    </Grid>
  </Grid>
</Window>
