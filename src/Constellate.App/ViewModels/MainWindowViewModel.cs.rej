+    /// <summary>
+    /// Helper for expansion-state properties to update the backing field and raise OnPropertyChanged.
+    /// </summary>
+    private void SetExpansionState(ref bool backingField, bool value, [System.Runtime.CompilerServices.CallerMemberName] string? propertyName = null)
+    {
+        if (backingField == value)
+            return;
+
+        backingField = value;
+        OnPropertyChanged(propertyName);
+    }
 
